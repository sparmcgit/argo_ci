# Copy this file, fill in the values, and pass it to generate.sh with
# --params. Values with defaults in generate.sh can be omitted to use them.

# --- Required, no default ---

# Short slug used to build all resource names: <name>-ci WorkflowTemplate
# and Sensor, <name>-gitea EventSource, <name>-ci-sensor-sa ServiceAccount.
# Must be unique among projects sharing the same NAMESPACE/EVENTS_NAMESPACE.
PROJECT_NAME=

# Gitea host:port used for both the clone URL and the commit-status API.
GITEA_HOST=192.0.2.10:3000

# Bare Gitea IP (no port), used for the NetworkPolicy CIDR restricting the
# webhook endpoint. Ask separately from GITEA_HOST in case that's ever a
# hostname instead of a raw IP.
GITEA_IP=192.0.2.10

# Gitea org/user path segment and repo slug, e.g. for
# http://192.0.2.10:3000/myorg/myproject -> myorg / myproject
GITEA_OWNER=
GITEA_REPO=

# golang image tag - pin to the version in go.mod.
GO_IMAGE=golang:1.26.5-alpine

# Integer percent; the workflow fails if combined coverage drops below this.
COVERAGE_THRESHOLD=70

# --- Optional, defaults shown ---

# Branch to build and the push-webhook filter value.
GIT_BRANCH=main

# Argo Workflows / Argo Events namespaces. Both must already have Argo
# Workflows/Events installed cluster-wide - see README.md prerequisites.
NAMESPACE=argo
EVENTS_NAMESPACE=argo-events

# Build tag gating a second, separately-run test suite (e.g. //go:build test
# files that `go test ./...` silently skips). Set to an empty string to
# disable the tagged-test step and --build-tags lint flag entirely, if the
# project has no such split.
BUILD_TAG=test

# The "context" string reported to Gitea's commit-status API and required
# in the branch protection "Status check patterns" field.
COMMIT_STATUS_CONTEXT=argo-ci
